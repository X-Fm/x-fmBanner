# X-Fm ZSH Theme

# Colors
_xfm_g=$'%{\033[1;92m%}'
_xfm_c=$'%{\033[1;96m%}'
_xfm_y=$'%{\033[1;93m%}'
_xfm_b=$'%{\033[1;94m%}'
_xfm_r=$'%{\033[1;91m%}'
_xfm_n=$'%{\033[0m%}'

# Prompt
PROMPT='${_xfm_g}╭─[${_xfm_y}D1D4X${_xfm_g}]─[${_xfm_c}%~${_xfm_g}]
${_xfm_g}╰─${_xfm_c}❯${_xfm_n} '

RPROMPT='${_xfm_b}[${_xfm_y}%T${_xfm_b}]${_xfm_n}'
